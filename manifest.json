{
	"manifest_version": "0.3",
	"name": "slides-mcp",
	"display_name": "Google Slides",
	"version": "0.1.0",
	"description": "Full programmatic control of Google Slides from Claude Desktop.",
	"author": {
		"name": "Jader Feijo"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jaderfeijo/google-slides-mcp"
	},
	"server": {
		"type": "node",
		"entry_point": "dist/index.js",
		"mcp_config": {
			"command": "node",
			"args": ["${__dirname}/dist/index.js"],
			"env": {
				"SLIDES_MCP_LOG_LEVEL": "${user_config.log_level}"
			}
		}
	},
	"compatibility": {
		"platforms": ["darwin"],
		"runtimes": {
			"node": ">=20"
		}
	},
	"user_config": {
		"log_level": {
			"type": "string",
			"title": "Log level",
			"description": "info or debug",
			"default": "info",
			"required": false
		}
	}
}
