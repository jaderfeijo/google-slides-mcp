{
	"name": "slides-mcp",
	"version": "1.0.0",
	"private": true,
	"description": "Google Slides MCP server for Claude Desktop",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
