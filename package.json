		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@anthropic-ai/mcpb": "^2.1.2",
		"@types/node": "^26.1.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
